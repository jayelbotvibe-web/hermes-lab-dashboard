#!/bin/bash
# forensics — One-command bring-up for Hermes Forensics Lab
# Run BEFORE opening Hermes Desktop. Then switch to forensics profile.
set -uo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}┌─────────────────────────────────────┐"
echo -e "│  Hermes Forensics Lab — Bring-Up    │"
echo -e "└─────────────────────────────────────┘${NC}"
echo ""

FORENSICS_DIR="/home/niel/forensics"
LUKS_IMG="/home/niel/forensics.img"
LUKS_NAME="forensics_crypt"
LUKS_KEYFILE="/home/niel/.forensics-keyfile"

# ── Phase 1: LUKS open + mount (inline, not from vault) ──
if mountpoint -q "$FORENSICS_DIR" 2>/dev/null; then
    echo -e "  ${GREEN}✓${NC} Already mounted"
else
    if [ ! -f "$LUKS_KEYFILE" ]; then
        echo -e "  ${RED}✗${NC} Keyfile not found at $LUKS_KEYFILE"
        echo "  Run: echo -n '<password>' > ~/.forensics-keyfile && chmod 600 ~/.forensics-keyfile"
        exit 1
    fi
    echo -n "  Opening LUKS..."
    sudo cryptsetup close "$LUKS_NAME" 2>/dev/null || true
    if sudo cryptsetup open "$LUKS_IMG" "$LUKS_NAME" --key-file="$LUKS_KEYFILE" 2>/dev/null; then
        echo -e " ${GREEN}OK${NC}"
    else
        echo -e " ${RED}FAILED${NC}"
        exit 1
    fi
    echo -n "  Mounting..."
    if sudo mount /dev/mapper/"$LUKS_NAME" "$FORENSICS_DIR" 2>/dev/null; then
        echo -e " ${GREEN}OK${NC}"
    else
        echo -e " ${RED}FAILED${NC}"
        exit 1
    fi
fi

df -h "$FORENSICS_DIR" 2>/dev/null | tail -1 | awk '{printf "  %s used / %s total\n", $3, $2}'

# ── Phase 2: Run forensics-up.sh (SIFT VM, Docker, canary) ──
echo ""
if [ -f "$FORENSICS_DIR/scripts/forensics-up.sh" ]; then
    # Skip LUKS phase since we already handled it; forensics-up.sh will see it's mounted
    bash "$FORENSICS_DIR/scripts/forensics-up.sh"
    UP_OK=$?
else
    echo -e "${RED}✗ forensics-up.sh not found inside vault${NC}"
    exit 1
fi

echo ""
echo -e "${CYAN}──────────────────────────────────────${NC}"
if [ $UP_OK -eq 0 ]; then
    echo -e "${GREEN}✅ Forensics Lab READY${NC}"
else
    echo -e "${YELLOW}⚠️  Some tools degraded — check canary output${NC}"
fi
echo ""
echo "Next: Switch to forensics profile in Hermes Desktop (bottom-left)"
echo "      or run: hermes desktop --profile forensics"
echo ""
