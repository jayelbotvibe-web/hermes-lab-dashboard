#!/usr/bin/env python3
"""Hermes Lab Tray — minimised, status-only, click to start/stop."""
import subprocess, threading, os, time, shutil

try:
    import gi
    gi.require_version('Gtk', '3.0')
    gi.require_version('AppIndicator3', '0.1')
    from gi.repository import Gtk, AppIndicator3, GLib
except ImportError:
    print("Missing deps: sudo apt install python3-gi gir1.2-gtk-3.0 gir1.2-appindicator3-0.1")
    exit(1)

def check(cmd):
    try: return subprocess.run(cmd, shell=True, capture_output=True, timeout=2).returncode == 0
    except: return False

def run_term(cmd):
    """Open a terminal for quick commands (VPN). Terminal closure doesn't matter."""
    term = shutil.which('x-terminal-emulator') or 'xterm'
    subprocess.Popen([term, '--', 'bash', '-c', f'{cmd}; echo; read -p "Press Enter..."'])

def run_bg(cmd):
    """Run a lab command detached from the tray. Survives tray restart/terminal close."""
    subprocess.Popen(['bash', '-c', cmd],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                     start_new_session=True)
    # Flash a notification so the user knows something is happening
    subprocess.Popen(['notify-send', 'Hermes Lab', f'Running: {cmd}',
                      '--icon=utilities-terminal', '--expire-time=3000'],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

class LabTray:
    def __init__(self):
        self.ind = AppIndicator3.Indicator.new("hermes", "utilities-terminal",
            AppIndicator3.IndicatorCategory.APPLICATION_STATUS)
        self.ind.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
        self._build()
        GLib.timeout_add_seconds(5, self._refresh)
        Gtk.main()

    def _build(self):
        m = Gtk.Menu()
        self._status = Gtk.MenuItem(label="Checking...")
        self._status.set_sensitive(False)
        m.append(self._status)
        m.append(Gtk.SeparatorMenuItem())

        # Lab start/stop → background (must survive terminal close)
        # VPN → terminal (quick commands, output is useful)
        for label, cmd, bg in [
            ("▶  Start Pentest",    "pentest",                                      True),
            ("■  Stop Pentest",     "bash ~/pentest-repo/scripts/pentest-down.sh",  True),
            ("🔒 VPN ON",           "sudo wg-quick up wg0 2>/dev/null && echo 'VPN connected' || echo 'VPN failed'", False),
            ("🔓 VPN OFF",          "sudo wg-quick down wg0 2>/dev/null; echo 'VPN disconnected'", False),
            ("▶  Start Forensics",  "forensics",                                    True),
            ("■  Stop Forensics",   "forensics-stop",                               True),
        ]:
            item = Gtk.MenuItem(label=label)
            fn = run_bg if bg else run_term
            item.connect("activate", lambda _,c=cmd,f=fn: f(c))
            m.append(item)

        m.append(Gtk.SeparatorMenuItem())
        q = Gtk.MenuItem(label="Quit")
        q.connect("activate", lambda _: Gtk.main_quit())
        m.append(q)
        m.show_all()
        self.ind.set_menu(m)

    def _refresh(self):
        p_luks = check("mountpoint -q /home/niel/pentest")
        p_ok = check("docker ps --format '{{.Names}}' | grep -q kali-web")
        p = "✓ READY" if p_luks and p_ok else ("⚠ ON" if p_luks else "○ OFF")

        f_luks = check("mountpoint -q /home/niel/forensics")
        f_ok = check("ssh -o ConnectTimeout=2 -o BatchMode=yes sansforensics@172.16.146.128 true >/dev/null 2>&1")
        f = "✓ READY" if f_luks and f_ok else "○ OFF"

        self._status.set_label(f"Pentest: {p}  |  Forensics: {f}")
        return True

if __name__ == '__main__':
    LabTray()
